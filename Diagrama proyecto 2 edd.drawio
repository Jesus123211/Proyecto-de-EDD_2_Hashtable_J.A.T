<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" version="29.6.1">
  <diagram name="Página-1" id="I0LrJ6-RQsvTGHeyPavu">
    <mxGraphModel dx="1042" dy="562" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nclass Documento {\n    - nombreDocumento : String\n    - tipoDocumento : String\n    - tamaño : int\n    - tienePrioridad : boolean\n    - instanteTiempo : int\n    + Documento(nombreDocumento: String, tipoDocumento: String, tamaño: int)\n    + getNombreDocumento() : String\n    + getTipoDocumento() : String\n    + getTamaño() : int\n    + getTienePrioridad() : boolean\n    + getInstanteTiempo() : int\n    + setTienePrioridad(tienePrioridad: boolean) : void\n    + setInstanteTiempo(instanteTiempo: int) : void\n    + toString() : String\n}\n\nclass HashTable {\n    - size : int\n    - count : int\n    - keys : String[]\n    - values : Usuario[]\n    + HashTable(size: int)\n    - hash(key: String) : int\n    + insert(key: String, value: Usuario) : void\n    + get(key: String) : Usuario\n    + containsKey(key: String) : boolean\n    + remove(key: String) : void\n    + getSize() : int\n    + getCount() : int\n    + getKeys() : String[]\n    + getValues() : Usuario[]\n}\n\nclass Interfaz {\n    - sistema : SistemaImpresion\n    - scanner : java.util.Scanner\n    + Interfaz(sistema: SistemaImpresion)\n    + iniciar() : void\n    - mostrarMenuPrincipal() : void\n    - registrarUsuario() : void\n    - enviarDocumento() : void\n    - eliminarDocumento() : void\n    - liberarImpresora() : void\n    - verEstadoImpresora() : void\n}\n\nclass MonticuloBinario {\n    - monticulo : Documento[]\n    - size : int\n    - capacity : int\n    + MonticuloBinario(capacity: int)\n    - parent(i: int) : int\n    - leftChild(i: int) : int\n    - rightChild(i: int) : int\n    - swap(i: int, j: int) : void\n    - heapifyUp(i: int) : void\n    - heapifyDown(i: int) : void\n    + insert(doc: Documento) : void\n    + extractMin() : Documento\n    + isEmpty() : boolean\n    + getSize() : int\n    + remove(nombreDoc: String) : boolean\n    + getMonticulo() : Documento[]\n}\n\nclass Proyecto_2_EDD_JAT {\n    + main(args: String[]) : void\n}\n\nclass SistemaImpresion {\n    - usuarios : HashTable\n    - colaImpresion : MonticuloBinario\n    - relojGlobal : int\n    + SistemaImpresion()\n    + registrarUsuario(nombre: String, tipoPrioridad: String) : void\n    + enviarDocumento(nombreUsuario: String, nombreDoc: String, tipoDoc: String, tamaño: int) : void\n    + eliminarDocumento(nombreUsuario: String, nombreDoc: String) : void\n    + liberarImpresora() : Documento\n    + verEstadoImpresora() : String\n    + getUsuarios() : HashTable\n    + getColaImpresion() : MonticuloBinario\n    + getRelojGlobal() : int\n}\n\nclass Usuario {\n    - nombreUsuario : String\n    - tipoPrioridad : String\n    - documentos : java.util.List&lt;Documento&gt;\n    + Usuario(nombreUsuario: String, tipoPrioridad: String)\n    + getNombreUsuario() : String\n    + getTipoPrioridad() : String\n    + getDocumentos() : java.util.List&lt;Documento&gt;\n    + agregarDocumento(doc: Documento) : void\n    + eliminarDocumento(nombreDoc: String) : boolean\n    + toString() : String\n}\n\nInterfaz --&gt; SistemaImpresion : \&quot;usa\&quot;\nSistemaImpresion --&gt; HashTable : \&quot;usuarios\&quot;\nSistemaImpresion --&gt; MonticuloBinario : \&quot;colaImpresion\&quot;\nHashTable --&gt; Usuario : \&quot;almacena\&quot;\nMonticuloBinario --&gt; Documento : \&quot;almacena\&quot;\nUsuario --&gt; Documento : \&quot;lista de documentos\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="NvvIZm3GKp3-rkQtWvrn-1">
